<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <!-- [MODIFICACION ] Se cambio ir.module.category a res.groups.privilege -->
        <!-- Privilege (groups category) for Uniform Management -->
        <record model="res.groups.privilege" id="module_privilege_cycles">
            <field name="name">Uniform Management</field>
        </record>

        <record id="group_cycles_user" model="res.groups">
            <field name="name">User</field>
            <!-- [MODIFICACION ] El campo category_id se renombro a privilege_id -->
            <field name="privilege_id" ref="module_privilege_cycles" />
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]" />
        </record>

        <record id="group_cycles_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="module_privilege_cycles" />
            <field name="implied_ids" eval="[(4, ref('group_cycles_user')), (4, ref('stock.group_stock_manager'))]" />
            <!-- [MODIFICACION] El campo users se estandarizo a user_ids -->
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
        </record>

        <!-- Multi-company record rules -->
        <record id="rule_garment_type_company" model="ir.rule">
            <field name="name">Garment Type: Company</field>
            <field name="model_id" ref="model_cycles_garment_type" />
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]" />
        </record>

        <record id="rule_movement_company" model="ir.rule">
            <field name="name">Garment Movement: Company</field>
            <field name="model_id" ref="model_cycles_movement" />
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]" />
        </record>

        <record id="rule_stock_lot_company" model="ir.rule">
            <field name="name">Stock Lot: Multi-company</field>
            <field name="model_id" ref="stock.model_stock_lot" />
            <field name="global" eval="True" />
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>
    </data>
</odoo>
