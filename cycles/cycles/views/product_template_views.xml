<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="view_product_template_form_inherit_cycles" model="ir.ui.view">
            <field name="name">product.template.form.inherit.cycles</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='tracking']" position="after">
                    <field name="cycles_is_garment" readonly="garment_type_id" />
                </xpath>
                <xpath expr="//page[@name='inventory']" position="inside">
                    <group string="Cycles">
                        <group>
                            <field name="garment_type_id" readonly="1" />
                            <field name="cycles_max_wash_cycles" />
                        </group>
                        <group>
                            <field name="cycles_warning_cycles_threshold" />
                            <field name="cycles_min_inventory" />
                            <field name="cycles_inactivity_days" />
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
