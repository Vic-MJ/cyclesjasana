<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_epc_replace_wizard_form" model="ir.ui.view">
        <field name="name">cycles.epc.replace.wizard.form</field>
        <field name="model">cycles.epc.replace.wizard</field>
        <field name="arch" type="xml">
            <form string="Reemplazar EPC Dañado">
                <sheet>
                    <div class="alert alert-info" role="alert" style="margin-bottom:0px;">
                        Ingrese el EPC de la etiqueta dañada y luego escanee la nueva etiqueta. 
                        El historial de la prenda y sus ciclos de lavado se mantendrán intactos.
                    </div>
                    <group>
                        <group>
                            <field name="old_epc" placeholder="Ej. E2801..."/>
                            <field name="new_epc" placeholder="Escanee la nueva etiqueta..."/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_replace_epc" type="object" string="Reemplazar" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_epc_replace_wizard" model="ir.actions.act_window">
        <field name="name">Reemplazar EPC Dañado</field>
        <field name="res_model">cycles.epc.replace.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
