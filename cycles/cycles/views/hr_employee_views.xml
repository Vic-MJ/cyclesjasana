<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <!-- Add garment stat button to employee form -->
        <record id="view_employee_form_inherit_cycles" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.cycles</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form" />
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button
            name="action_view_garments"
            type="object"
            class="oe_stat_button"
            icon="fa-tags"
            invisible="garment_count == 0"
          >
                        <field name="garment_count" widget="statinfo" string="Prendas" />
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
